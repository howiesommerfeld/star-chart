# Copy to .env.local for dev. In production these are Vercel env vars.

# Long random path segment for the family URL, e.g. output of: openssl rand -hex 16
FAMILY_TOKEN=dev

# 4-6 digit parent PIN for the confirm/config gate
PARENT_PIN=1234

# Secret for signing the parent session cookie: openssl rand -hex 32
SESSION_SECRET=dev-secret-change-me

# Turso. Leave unset in dev to use file:local.db
# TURSO_DATABASE_URL=libsql://star-chart-<org>.turso.io
# TURSO_AUTH_TOKEN=
